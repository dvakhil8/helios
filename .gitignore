# ── Python ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.coverage
htmlcov/
.ipynb_checkpoints/
.jupyter_cache/

# ── Secrets ────────────────────────────────────────────────────────────
# NEVER commit .env — contains DATABRICKS_TOKEN, OPENAI_API_KEY, etc.
.env
.env.local
.env.*.local
*.pem
*.key

# ── Eval / propose run artifacts ───────────────────────────────────────
# These contain per-run state regenerated by `helios eval run` / `helios propose`.
# `evals/proposals/` ESPECIALLY can contain sensitive prod data:
#   - notebook_original.txt: raw prod notebook source (likely proprietary)
#   - messages.json: full agent conversation including prod SQL + table names
#   - trace.jsonl / trace.live.jsonl: every prod query the agent ran
#   - proposal.md / proposal.json: prod table FQNs, baseline stats, diffs
# Synthetic fixture definitions stay tracked (evals/fixtures/).
evals/results/
evals/proposals/
evals/baselines.json

# ── Local agent / IDE state ────────────────────────────────────────────
.claude/
.cursor/
.idea/
.vscode/

# ── Editor swap / temp files ───────────────────────────────────────────
*.swp
*.swo
*~

# ── Logs ───────────────────────────────────────────────────────────────
*.log

# ── OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
